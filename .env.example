# CafeSphere Backend Environment Configuration Template
PORT=5000
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# MongoDb Database Configuration
MongoDbSettings__ConnectionString=
MongoDbSettings__DatabaseName=CafeSphereDb
MongoDbSettings__AutoCreateIndexes=true
MongoDbSettings__ServerSelectionTimeoutSeconds=3

# Security & JWT Authentication
JwtSettings__Secret=YOUR_PRODUCTION_JWT_SECRET_KEY_HERE
JwtSettings__Issuer=CafeSphereAPI
JwtSettings__Audience=CafeSphereApp
JwtSettings__ExpiryMinutes=60
JwtSettings__RefreshTokenExpiryDays=7

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:5247,https://cafespheree.netlify.app
